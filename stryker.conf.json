{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "vitest",
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/domain/**/*.ts",
    "src/application/**/*.ts",
    "!src/**/*.d.ts",
    "!src/**/index.ts",
    "!src/**/ports/**"
  ],
  "thresholds": { "high": 90, "low": 80, "break": 80 }
}
