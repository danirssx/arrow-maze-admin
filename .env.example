# Base URL of the Arrow Maze backend API the admin dashboard talks to.
# Local backend default:
VITE_API_BASE_URL=http://localhost:3000

# Production build (AD-11): Vite inlines VITE_API_BASE_URL at BUILD time, so set it in the
# host's build environment (Netlify/Vercel "VITE_API_BASE_URL" env var), e.g.
#   VITE_API_BASE_URL=https://api.arrowmaze.example
# The admin's deployed origin must also be added to the backend CORS_ORIGIN (BE-04,
# comma-separated). Deploy runbook: docs/deploy.md.
